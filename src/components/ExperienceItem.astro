---
import GreaterThanIcon from "../icons/GreaterThan.astro";

interface Props {
	title: string;
	company: string;
	description: string;
	link: string | null;
	date: string;
}

const { title, company, description, link, date } = Astro.props;
---

<div
	class="mx-12 pb-10 relative grid md:grid-cols-5 md:gap-10 md:space-x-4] before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-white/15 before:content-[''] animate"
>
	<div class="pb-5 relative md:col-span-2">
		<div class="top-0 sticky">
			<span
				class="-left-[42px] absolute rounded-full text-5xl text-blue-500 dark:text-yellow-300"
				>&bull;</span
			>
			<h3 class="text-xl font-bold text-blue-500 dark:text-yellow-300">
				{title}
			</h3>
			<h4 class="text-lg font-semibold text-gray-600 dark:text-white">
				{company}
			</h4>
			<time class="p-0 m-0 text-sm text-gray-600/80 dark:text-white/80"
				>{date}</time
			>
		</div>
	</div>
	<p
		class="pb-4 relative flex flex-col gap-2 md:col-span-3 text-gray-600 dark:text-gray-300"
	>
		{description}
		{
			link && (
				<a
					href={link}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center text-lg font-medium text-blue-400 hover:text-blue-500 dark:text-yellow-200 dark:hover:text-yellow-300"
				>
					Saber más <GreaterThanIcon />
				</a>
			)
		}
	</p>
</div>
