---
import LinkedInIcon from "../icons/LinkedIn.astro";
import MailIcon from "../icons/Mail.astro";
import GitHubIcon from "../icons/GitHub.astro";
import Badge from "./Badge.astro";
import SocialLink from "./SocialLink.astro";
---

<div class="max-w-xl">
	<div class="flex gap-4 mb-4">
		<img
			class="rounded-full shadow-lg size-16"
			src="https://avatars.githubusercontent.com/u/118027004"
			alt="MaxiV95"
			loading="lazy"
		/>
		<a
			href="https://www.linkedin.com/in/maximilianovanmegroot/"
			target="_blank"
			rel="noopener noreferrer"
			class="flex items-center transition md:justify-center md:hover:scale-105"
		>
			<Badge>Disponible para trabajar</Badge>
		</a>
	</div>
	<h1
		class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
	>
		Hi! 👋 I'm Maximiliano <br /> Van Megroot
	</h1>
	<p
		class="mt-6 text-xl text-gray-800 dark:text-gray-300 [&>strong]:text-blue-600 [&>strong]:font-semibold dark:[&>strong]:text-yellow-300 text-pretty"
	>
		Resolución de problemas y atención al detalle.<br />
		<strong>Full Stack Web Developer</strong> de Córdoba, Argentina.<br />
		Especializado en el desarrollo de aplicaciones web.
	</p>
	<nav class="flex flex-wrap gap-4 mt-8">
		<SocialLink href="https://www.linkedin.com/in/maximilianovanmegroot/">
			<LinkedInIcon class="size-4" />
			LinkedIn
		</SocialLink>
		<SocialLink href="https://github.com/MaxiV95">
			<GitHubIcon class="size-4" />
			GitHub
		</SocialLink>
		<SocialLink href="mailto:maximilianovanmegroot@gmail.com">
			<MailIcon class="size-4" />
			Send email
		</SocialLink>
	</nav>
</div>
