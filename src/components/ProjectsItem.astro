---
import SocialLink from "./SocialLink.astro";
import GitHubIcon from "../icons/GitHub.astro";
import LinkIcon from "../icons/Link.astro";
import { type Tag } from "../icons/tagsTechnologies";

interface Props {
	title: string;
	description: string;
	image: string;
	tags: Tag[];
	github: string | null;
	link: string | null;
}

const { title, description, tags, image, github, link } = Astro.props;
---

<article
	class="flex flex-col space-x-0 space-y-4 group md:flex-row md:space-x-8 md:space-y-0 animate"
>
	<div class="w-full md:w-1/2">
		<div
			class="duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-500 lg:hover:bg-gray-500/50"
		>
			<img
				alt="Project"
				class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
				loading="lazy"
				src={image}
			/>
		</div>
	</div>

	<div class="w-full md:w-1/2 md:max-w-lg flex flex-col">
		<div class="flex flex-wrap gap-1">
			{tags.map((tag) => <img alt={tag.name} loading="lazy" src={tag.url} />)}
		</div>

		<h3 class="mt-4 text-2xl font-bold text-gray-800 dark:text-gray-100">
			{title}
		</h3>

		<p class="mt-1 text-gray-700 dark:text-gray-400">{description}</p>

		<div class="mt-4 flex items-end justify-start gap-x-4">
			{
				github && (
					<SocialLink href={github}>
						<GitHubIcon class="size-6" />
						Code
					</SocialLink>
				)
			}
			{
				link && (
					<SocialLink href={link}>
						<LinkIcon class="size-4" />
						Preview
					</SocialLink>
				)
			}
		</div>
	</div>
</article>
