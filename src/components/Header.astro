---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
	{
		title: "Home",
		label: "home",
		url: "/#home",
	},
	{
		title: "Experience",
		label: "experience",
		url: "/#experience",
	},
	{
		title: "Projects",
		label: "projects",
		url: "/#projects",
	},
	{
		title: "About",
		label: "about",
		url: "/#about",
	},
];
---

<header
	class="mx-auto mt-2 w-full top-0 fixed z-10 flex items-center justify-center"
>
	<nav
		class="px-2 flex gap-1 justify-center items-center font-medium rounded-full text-sm md:text-lg text-gray-600 dark:text-gray-200"
	>
		{
			navItems.map((link) => (
				<a
					class="p-2 hover:text-blue-500 dark:hover:text-yellow-400"
					aria-label={link.label}
					href={link.url}
				>
					{link.title}
				</a>
			))
		}
		<ThemeToggle />
	</nav>
</header>

<script>
	document.addEventListener("astro:page-load", () => {
		const sections = document.querySelectorAll("section");
		const navItems = document.querySelectorAll("header nav a");

		const callback = (entries: any[]) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					navItems.forEach((item) => {
						if (item.getAttribute("aria-label") == entry.target.id) {
							item.classList.add("text-blue-600");
							item.classList.add("dark:text-yellow-300");
						} else {
							item.classList.remove("text-blue-600");
							item.classList.remove("dark:text-yellow-300");
						}
					});
				}
			});
		};

		const observer = new IntersectionObserver(callback, {
			root: null,
			rootMargin: "0px",
			threshold: 0.3,
		});

		sections.forEach((section) => {
			observer.observe(section);
		});

		// Cleanup function
		document.onvisibilitychange = () => {
			if (document.visibilityState === "hidden") {
				observer.disconnect();
			} else {
				sections.forEach((section) => {
					observer.observe(section);
				});
			}
		};
	});
</script>

<style>
	nav {
		animation: nav-shadown both;
		animation-timeline: scroll();
		animation-range: 0 500px;
	}
	@keyframes nav-shadown {
		to {
			@apply shadow-lg ring-1 backdrop-blur bg-gray-500/40;
		}
	}
</style>
