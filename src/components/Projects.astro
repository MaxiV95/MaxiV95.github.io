---
import SocialLink from "./SocialLink.astro";
import GitHub from "../icons/GitHub.astro";
import Link from "../icons/Link.astro";
import { TAGS } from "../icons/tagsTechnologies";

const PROJECTS = [
	{
		title: "Api Blog",
		description:
			"Aplicación para: buscar, crear, editar, filtrar y ordenar recetas. Es un sitio web dinámico con estilos en CSS en cascada. Consumo de API del sitio web Spoonacular y sustentación de información en base de datos. Extra; botón para cambiar la paleta de colores.",
		tags: [
			TAGS.Node,
			TAGS.JavaScript,
			TAGS.React,
			TAGS.Redux,
			TAGS.Express,
			TAGS.PostgreSQL,
		],
		image: "/projects/food.webp",
		github: "https://github.com/MaxiV95/PI-Food",
		link: "",
	},
	{
		title: "Blog",
		description:
			"API con funcionalidades de CRUD completo para un blog. Este proyecto abarca desde el registro y autenticación de usuarios, gestión de administradores hasta la interacción con una base de datos MongoDB. Además, incorporé características avanzadas como un chat en vivo implementado con Sockets y un bot de eventos que utiliza Webhooks de Github para notificar automáticamente cambios relevantes en un canal de Discord.",
		tags: [TAGS.Node, TAGS.TypeScript, TAGS.Nest, TAGS.MongoDB],
		image: "/projects/blog.webp",
		github: "https://github.com/MaxiV95/tpf-blog",
		link: "",
	},
];
---

<div class="flex flex-col gap-y-16">
	{
		PROJECTS.map(({ title, description, tags, image, github, link }) => (
			<article class="flex flex-col space-x-0 space-y-4 group md:flex-row md:space-x-8 md:space-y-0">
				<div class="w-full md:w-1/2">
					<div class="duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-500 lg:hover:bg-gray-500/50">
						<img
							alt="Project"
							class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
							loading="lazy"
							src={image}
						/>
					</div>
				</div>

				<div class=" w-full md:w-1/2 md:max-w-lg flex flex-col">
					<ul class="flex flex-row gap-x-2">
						{tags.map((tag) => (
							<li>
								<img alt={tag.name} loading="lazy" src={tag.url} />
							</li>
						))}
					</ul>

						<h3 class="mt-4 text-2xl font-bold text-gray-800 dark:text-gray-100">
							{title}
						</h3>

						<div class="mt-1 text-gray-700 dark:text-gray-400">
							{description}
						</div>


						<div class="mt-4 flex items-end justify-start gap-x-4">
							{github && (
								<SocialLink href={github}>
									<GitHub class="size-6" />
									Code
								</SocialLink>
							)}
							{link && (
								<SocialLink href={link}>
									<Link class="size-4" />
									Preview
								</SocialLink>
							)}
						</div>
				</div>
			</article>
		))
	}
</div>
